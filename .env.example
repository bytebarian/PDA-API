# API
PDA_APP_NAME=PDA API
PDA_APP_VERSION=0.1.0
PDA_API_PREFIX=/

# Database – SQLite default for local development without Docker
PDA_DATABASE_URL=sqlite+aiosqlite:///./pda.db

# Database – PostgreSQL via Docker Compose (uncomment and use instead of SQLite above)
# PDA_DATABASE_URL=postgresql+asyncpg://pda:pda_dev@localhost:5432/pda

# Docker Compose PostgreSQL credentials (used by docker-compose.yml)
# These are local-dev defaults only – do not use in production
POSTGRES_DB=pda
POSTGRES_USER=pda
POSTGRES_PASSWORD=pda_dev

# Local storage
PDA_STORAGE_PATH=./storage
PDA_ALLOWED_FILE_TYPES=["application/pdf","text/plain","image/png","image/jpeg","image/jpg"]
PDA_MAX_FILE_SIZE_BYTES=10485760

# Local model provider defaults
PDA_MODEL_PROVIDER=local
PDA_MODEL_NAME=llama3.1:8b-instruct

# OCR defaults
PDA_OCR_PROVIDER=tesseract
PDA_OCR_LANGUAGE=eng
PDA_OCR_DPI=300
PDA_TESSERACT_CMD=tesseract
PDA_TESSERACT_LANGUAGES=eng
PDA_TESSERACT_TIMEOUT_SECONDS=120
PDA_TESSERACT_PSM=6
PDA_TESSERACT_OEM=3
PDA_OCR_PREPROCESS_IMAGES=true

# Embeddings defaults
PDA_EMBEDDING_PROVIDER=ollama
PDA_OLLAMA_BASE_URL=http://localhost:11434
PDA_EMBEDDING_MODEL=all-minilm
PDA_EMBEDDING_DIMENSIONS=1536
PDA_EMBEDDING_DISTANCE=cosine
PDA_EMBEDDING_BATCH_SIZE=16
PDA_EMBEDDING_TIMEOUT_SECONDS=60
PDA_EMBEDDING_TRUNCATE=true
