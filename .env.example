# API
PDA_APP_NAME=PDA API
PDA_APP_VERSION=0.1.0
PDA_API_PREFIX=/

# Database
PDA_DATABASE_URL=sqlite+aiosqlite:///./pda.db

# Local storage
PDA_STORAGE_PATH=./storage
PDA_ALLOWED_FILE_TYPES=["application/pdf","text/plain","image/png","image/jpeg"]
PDA_MAX_FILE_SIZE_BYTES=10485760

# Local model provider defaults
PDA_MODEL_PROVIDER=local
PDA_MODEL_NAME=llama3.1:8b-instruct

# OCR defaults
PDA_OCR_PROVIDER=tesseract
PDA_OCR_LANGUAGE=eng
PDA_OCR_DPI=300
